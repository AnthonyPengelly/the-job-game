# ── The Job build pipeline — copy to .env and fill in. NEVER commit .env. ──

# Source of truth (the agents clone this fresh each run)
GITHUB_REPO=youruser/the-job
GITHUB_TOKEN=ghp_xxx           # a token with push access; OR set USE_GH=1 and `gh auth login`
USE_GH=0
GIT_USER_NAME=the-job-agent
GIT_USER_EMAIL=agent@thejob.local

# Auth — provide ONE. OAuth token keeps build spend separable from interactive use.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Model tiers. Leave blank to use the claude CLI default, or pin a model string.
# Recommended: strongest for planning, mid for the rest. Set to the model
# identifiers available to your account (e.g. an Opus for PLAN, a Sonnet for the rest).
MODEL_PLAN=
MODEL_BUILD=
MODEL_REVIEW=
MODEL_QA=
MODEL_PARSE=claude-haiku-4-5-20251001  # marker extraction after each agent run; override only if Haiku is unavailable

# Loop bounds (cost guardrails)
MAX_REVIEW_ROUNDS=5
MAX_QA_ROUNDS=3
RATE_LIMIT_DEFAULT_SLEEP=900

# What the container runs: orchestrate (default) | "epic E5" | preflight
RUN=orchestrate
SMOKE=0
